{
  "manifest_version": 3,
  "name": "DarkGuard by Trusten",
  "version": "1.0.0",
  "description": "Detects dark patterns on any webpage and scores the site A-F.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>", "https://generativelanguage.googleapis.com/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["overlay.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
